# --- Authentication ---
EDGE_TTS_INTERNAL_TOKEN=change-me-long-random-token

# --- Public URL ---
# The base URL that Nginx uses to serve MP3 files.
# Set this to the public domain/IP of the VPS node.
# Examples: http://tts-node1.example.com/media, http://1.2.3.4/media
EDGE_TTS_PUBLIC_BASE_URL=http://localhost/media

# --- Redis (internal, no need to change) ---
REDIS_URL=redis://redis:6379/0

# --- Segment settings ---
EDGE_TTS_SEGMENT_META_TTL_SECONDS=233280
EDGE_TTS_SEGMENT_LOCK_SECONDS=180
EDGE_TTS_SEGMENT_WAIT_SECONDS=30
EDGE_TTS_MAX_SEGMENT_CHARS=8000
EDGE_TTS_FAILED_TEXT_LOG_CHARS=1200

# Test-only: force failure on a specific segment index
EDGE_TTS_FORCE_FAIL_SEGMENT_INDEX=-1

# --- Storage (local only) ---
EDGE_TTS_LOCAL_DIR=/data/edge_tts
EDGE_TTS_LOCAL_PREFIX=tts

# --- Cleanup (auto-delete old MP3 files) ---
EDGE_TTS_CLEANUP_MAX_AGE_SECONDS=259200
EDGE_TTS_CLEANUP_INTERVAL_SECONDS=3600

# --- Workload shaping ---
EDGE_TTS_CONCURRENCY=64
EDGE_TTS_METRICS_CACHE_SECONDS=10

# --- Upstream synth behavior ---
EDGE_TTS_CONNECT_TIMEOUT=4
EDGE_TTS_RECEIVE_TIMEOUT=15
EDGE_TTS_RETRIES=10
EDGE_TTS_RETRY_SLEEP_MIN_SECONDS=0.1
EDGE_TTS_RETRY_SLEEP_MAX_SECONDS=0.2
EDGE_TTS_HEDGE_AFTER_ATTEMPTS=4

# --- Webhook ---
EDGE_TTS_WEBHOOK_TIMEOUT=10
EDGE_TTS_WEBHOOK_MAX_RETRIES=5

# --- CORS Origin ---
# The origin domain to allow CORS requests from (e.g. https://truyendich.ai)
ALLOW_ORIGIN=https://truyendich.ai
